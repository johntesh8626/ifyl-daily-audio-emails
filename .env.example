# Dropbox source folder: e.g. "Intelligence for Your Life emails"
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT_PATH=/John Tesh/ifyl-daily-audio-emails
DROPBOX_SHARED_LINK_URL=
DROPBOX_INCLUDE_REGEX=Intelligence for Your Life emails|IFYL emails|daily email|daily audio emails|ifyl-daily-audio-emails

# OpenAI transcription
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Draft/listen links
AUDIO_PUBLIC_BASE_URL=
DEFAULT_LISTEN_URL=

# Cloudflare R2 public audio delivery
R2_AUDIO_DOMAIN=
R2_AUDIO_PREFIX=audio/ifyl-daily-audio-emails
R2_BUCKET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
WRANGLER_BIN=wrangler

# Kit/ConvertKit target metadata. Default is a draft queue: John chooses
# the final list, broadcast, or sequence destination when he is ready to send.
KIT_TARGET_MODE=draft_queue
KIT_DRAFT_HOLDING_TAG=SYSTEM - IFYL Daily Audio Drafts - Do Not Send
KIT_SEQUENCE_ID=
KIT_BROADCAST_TAG=
KIT_API_KEY=
KIT_API_SECRET=
