# Dropbox source folder: e.g. "Intelligence for Your Life emails"
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_SHARED_LINK_URL=
DROPBOX_INCLUDE_REGEX=Intelligence for Your Life emails|IFYL emails|daily email

# OpenAI transcription
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Draft/listen links
AUDIO_PUBLIC_BASE_URL=
DEFAULT_LISTEN_URL=

# Kit/ConvertKit target metadata. The first version writes Kit-ready drafts;
# Codex still asks before touching Kit.
KIT_TARGET_MODE=undecided
KIT_SEQUENCE_ID=
KIT_BROADCAST_TAG=
KIT_API_KEY=
KIT_API_SECRET=
